---
interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li>
	<a 
		href={href} 
		class="block p-6 rounded-lg border border-gray-300 bg-gray-50 hover:bg-gradient-to-br hover:from-blue-400 hover:to-purple-500 hover:border-transparent hover:text-white transition-all duration-300"
	>
		<h2 class="text-xl font-bold mb-2">
			{title}
			<span class="text-lg">&rarr;</span>
		</h2>
		<p class="text-gray-600">
			{body}
		</p>
	</a>
</li>
<style>
	/* Los estilos se pueden mantener aquí si es necesario, pero Tailwind maneja el diseño */
</style>
