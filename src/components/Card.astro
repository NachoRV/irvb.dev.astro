---
interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li>
	<a href={href} class="card">
		<div class="card-content">
			<h2 class="card-title">
				{title}
				<span class="arrow">→</span>
			</h2>
			<p class="card-body">{body}</p>
		</div>
	</a>
</li>

<style>
	li {
		list-style: none;
	}

	.card {
		display: block;
		padding: 24px;
		border-radius: 12px;
		background: linear-gradient(135deg, rgba(224, 204, 250, 0.1), rgba(168, 85, 247, 0.05));
		border: 1px solid rgba(168, 85, 247, 0.15);
		text-decoration: none;
		color: inherit;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		height: 100%;
	}

	.card:hover {
		border-color: rgba(168, 85, 247, 0.3);
		background: linear-gradient(135deg, rgba(224, 204, 250, 0.15), rgba(168, 85, 247, 0.08));
		box-shadow: 0 20px 40px rgba(168, 85, 247, 0.12);
		transform: translateY(-4px);
	}

	.card-content {
		display: flex;
		flex-direction: column;
	}

	.card-title {
		margin: 0 0 12px 0;
		font-size: 1.25rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--color-black);
		display: flex;
		align-items: center;
		gap: 8px;
		transition: color 0.3s ease;
	}

	:root.dark .card-title {
		color: var(--color-white);
	}

	.card:hover .card-title {
		color: rgba(168, 85, 247, 0.9);
	}

	.arrow {
		font-size: 1.1rem;
		transition: transform 0.3s ease;
	}

	.card:hover .arrow {
		transform: translateX(4px);
	}

	.card-body {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--color-gray);
		transition: color 0.3s ease;
	}

	:root.dark .card-body {
		color: rgba(255, 255, 255, 0.7);
	}

	.card:hover .card-body {
		color: var(--color-gray);
	}

	:root.dark .card {
		background: linear-gradient(135deg, rgba(168, 85, 247, 0.08), rgba(168, 85, 247, 0.03));
		border-color: rgba(168, 85, 247, 0.2);
	}

	:root.dark .card:hover {
		background: linear-gradient(135deg, rgba(168, 85, 247, 0.12), rgba(168, 85, 247, 0.06));
		border-color: rgba(168, 85, 247, 0.35);
		box-shadow: 0 20px 40px rgba(168, 85, 247, 0.15);
	}

	@media (max-width: 768px) {
		.card {
			padding: 16px;
		}

		.card-title {
			font-size: 1.1rem;
		}

		.card-body {
			font-size: 0.9rem;
		}
	}
</style>
