---
interface Props {
  text: string;
  color?: 'pink' | 'purple' | 'blue' | 'yellow' | 'green';
}

const { text, color = 'pink' } = Astro.props;

const colorMap: Record<string, string> = {
  pink: '#E04CF2',
  purple: '#A855F7',
  blue: '#3B82F6',
  yellow: '#FBBF24',
  green: '#22C55E',
};

const bgColor = colorMap[color] || colorMap.pink;
---

<span class="highlight-container">
  <span class="highlight-text">{text}</span>
  <span class="highlight-bg" style={`background-color: ${bgColor}`}></span>
</span>

<style>
  .highlight-container {
    display: inline-block;
    position: relative;
    text-decoration-color: currentColor;
  }

  .highlight-text {
    position: relative;
    z-index: 10;
  }

  .highlight-bg {
    position: absolute;
    bottom: -1px;
    left: -0.5rem;
    right: -0.5rem;
    height: .75rem;
    opacity: 0.3;
  }

  @media (min-width: 768px) {
    .highlight-bg {
      height: 1rem;
    }
  }
</style>
