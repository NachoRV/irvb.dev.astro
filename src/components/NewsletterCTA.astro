---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "¿Quieres estar al día?",
  description = "Suscríbete a mi newsletter para recibir los últimos artículos, tips y recursos sobre desarrollo web, emprendimiento y programación.",
} = Astro.props;
---

<aside class="newsletter-cta">
  <div class="newsletter-content">
    <h3 class="newsletter-title">{title}</h3>
    <p class="newsletter-description">{description}</p>
    
    <form class="newsletter-form" action="#" method="POST">
      <input
        type="email"
        placeholder="tu@email.com"
        required
        class="newsletter-input"
      />
      <button type="submit" class="newsletter-button">Suscribirse</button>
    </form>
    
    <p class="newsletter-privacy">
      No spam, solo contenido valioso. <a href="/politica-de-privacidad">Política de privacidad</a>
    </p>
  </div>
</aside>

<style>
  .newsletter-cta {
    background: linear-gradient(135deg, rgba(224, 204, 250, 0.12), rgba(168, 85, 247, 0.08));
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 12px;
    padding: 2.5rem;
    margin: 3rem 0;
    max-width: 600px;
  }

  :root.dark .newsletter-cta {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.12), rgba(168, 85, 247, 0.06));
    border-color: rgba(168, 85, 247, 0.25);
  }

  .newsletter-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .newsletter-title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-black);
  }

  :root.dark .newsletter-title {
    color: var(--color-white);
  }

  .newsletter-description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
  }

  :root.dark .newsletter-description {
    color: rgba(255, 255, 255, 0.7);
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 8px;
    background: var(--color-white);
    color: var(--color-black);
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  :root.dark .newsletter-input {
    background: rgba(0, 0, 0, 0.2);
    color: var(--color-white);
    border-color: rgba(168, 85, 247, 0.3);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: rgba(168, 85, 247, 0.5);
    box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.1);
  }

  .newsletter-input::placeholder {
    color: var(--color-gray);
  }

  :root.dark .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .newsletter-button {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.9), rgba(224, 204, 250, 0.7));
    color: white;
    border: 1px solid rgba(168, 85, 247, 0.5);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .newsletter-button:hover {
    background: linear-gradient(135deg, rgba(168, 85, 247, 1), rgba(224, 204, 250, 0.8));
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(168, 85, 247, 0.2);
  }

  .newsletter-button:active {
    transform: translateY(0);
  }

  .newsletter-privacy {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-gray);
    text-align: center;
  }

  :root.dark .newsletter-privacy {
    color: rgba(255, 255, 255, 0.6);
  }

  .newsletter-privacy a {
    color: rgba(168, 85, 247, 0.9);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .newsletter-privacy a:hover {
    color: rgba(168, 85, 247, 1);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .newsletter-cta {
      padding: 1.75rem;
      margin: 2rem 0;
    }

    .newsletter-title {
      font-size: 1.15rem;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .newsletter-button {
      width: 100%;
    }
  }
</style>
