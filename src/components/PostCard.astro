---
interface Props {
	title: string;
	body: string;
	href: string;
	img: string;
}

const { href, title, body, img } = Astro.props;
---

<article class="post-card">
	<a href={href} class="post-link">
		
		<div class="content">
			<h2 class="title">{title}</h2>
			<p class="description">{body}</p>
			<span class="read-more">Leer artículo &rarr;</span>
		</div>
	</a>

	<style>
		.post-card {
			border-radius: 8px;
			overflow: hidden;
			background: var(--bg-elevated);
			border: 1px solid var(--border);
			transition: all 0.2s ease;
		}

		.post-card:hover {
			border-color: var(--border-hover);
		}

		.post-link {
			display: flex;
			flex-direction: column;
			height: 100%;
			text-decoration: none;
			color: inherit;
		}


		.content {
			flex: 1;
			display: flex;
			flex-direction: column;
			padding: 1.25rem;
		}

		.title {
			margin: 0 0 0.5rem 0;
			font-size: 1.125rem;
			font-weight: 600;
			line-height: 1.4;
			color: var(--fg);
			letter-spacing: -0.01em;
		}

		.description {
			margin: 0 0 1rem 0;
			font-size: 0.875rem;
			line-height: 1.6;
			color: var(--fg-muted);
			flex: 1;
		}

		.read-more {
			font-size: 0.8125rem;
			font-weight: 500;
			color: var(--fg-subtle);
			font-family: var(--font-mono);
			transition: color 0.15s ease;
		}

		.post-card:hover .read-more {
			color: var(--fg);
		}

		@media (max-width: 768px) {
			.content {
				padding: 1rem;
			}

			.title {
				font-size: 1rem;
			}

			.description {
				font-size: 0.8125rem;
			}
		}
	</style>
</article>
