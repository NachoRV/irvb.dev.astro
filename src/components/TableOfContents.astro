---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;

// Filtrar solo h2 y h3
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Si hay menos de 3 headings, no mostrar TOC
if (filteredHeadings.length < 3) {
  export const ASTRO_REMOVED = true;
}
---

<nav class="toc">
  <div class="toc-header">
    <h3>Contenidos</h3>
  </div>
  <ul class="toc-list">
    {filteredHeadings.map((heading) => (
      <li class={`toc-item toc-depth-${heading.depth}`}>
        <a href={`#${heading.slug}`}>{heading.text}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .toc {
    background: linear-gradient(135deg, rgba(224, 204, 250, 0.08), rgba(168, 85, 247, 0.04));
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    max-width: 800px;
  }

  :root.dark .toc {
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.08), rgba(168, 85, 247, 0.03));
    border-color: rgba(168, 85, 247, 0.2);
  }

  .toc-header {
    margin: 0 0 1rem 0;
  }

  .toc-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(168, 85, 247, 0.9);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin: 0.5rem 0;
    padding-left: 0;
  }

  .toc-item.toc-depth-2 a {
    display: block;
    padding: 0.5rem 0;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-gray);
    text-decoration: none;
    transition: all 0.3s ease;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
  }

  .toc-item.toc-depth-3 {
    margin-left: 1rem;
  }

  .toc-item.toc-depth-3 a {
    display: block;
    padding: 0.35rem 0;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-gray);
    text-decoration: none;
    transition: all 0.3s ease;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
  }

  .toc-item a:hover {
    color: rgba(168, 85, 247, 0.9);
    border-left-color: rgba(168, 85, 247, 0.5);
  }

  :root.dark .toc-item a,
  :root.dark .toc-item.toc-depth-3 a {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .toc {
      margin: 1.5rem 0;
      padding: 1rem;
    }

    .toc-item.toc-depth-2 a,
    .toc-item.toc-depth-3 a {
      font-size: 0.9rem;
    }
  }
</style>
