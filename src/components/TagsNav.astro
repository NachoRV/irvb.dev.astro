---
interface Props {
  tags: string[];
  activeTag?: string;
  onTagClick?: (tag: string) => void;
}

const { tags, activeTag } = Astro.props;
---

<nav>
  <div class="tags-container">
    <ul class="tags-list">
      {
        tags.map((tag) => (
          <li class={`tag-item ${activeTag === tag ? "active" : ""}`}>
            <a
              class={`tag-link ${activeTag === tag ? "active" : ""}`}
              href={`/tags/${tag}`}
            >
              {tag}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .tags-container {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .tags-list {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
    list-style: none;
    text-decoration: none;
  }

  .tags-list li {
    text-decoration: none;
    list-style: none;
  }
  ul li::before {
    content: "";
  }

  .tag-item {
    margin-bottom: 0;
    list-style: none;
  }

  .tag-item:not(:last-child)::after {
    display: none;
  }

  .tag-link {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    min-width: 100px;
    text-align: center;
    text-transform: uppercase;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(var(--accent-light), 0.12),
      transparent
    );
    border: 1px solid var(--color-pink-text);
    color: var(--color-black);
    text-decoration: none;
    font-size: 0.95rem;
    transition:
      transform 0.12s ease,
      color 0.12s ease,
      background 0.12s ease;
  }

  .tag-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  .tag-link:active {
    transform: translateY(0);
  }

  .tag-link.active {
    background: rgba(var(--accent), 0.2);
    border-color: var(--color-pink-text);
    font-weight: bold;
  }

  :root.dark .tag-link {
    color: var(--color-white);
  }

  :root.dark .tag-link.active {
    background: rgba(var(--accent), 0.3);
  }
</style>
