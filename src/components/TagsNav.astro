---
interface Props {
  tags: string[];
  activeTag?: string;
  onTagClick?: (tag: string) => void;
}

const { tags, activeTag } = Astro.props;
---

<nav>
  <div class="tags-container">
    <ul class="tags-list">
      {
        tags.map((tag) => (
          <li class="tag-item">
            <a
              class={`tag-link ${activeTag === tag ? "active" : ""}`}
              href={`/tags/${tag}`}
            >
              {tag}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .tags-container {
    display: flex;
    justify-content: flex-start;
  }

  .tags-list {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tags-list li {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tags-list li::before {
    content: "";
    display: none;
  }

  .tag-item {
    margin-bottom: 0;
  }

  .tag-link {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    transition: all 0.15s ease;
  }

  .tag-link:hover {
    background: var(--bg-muted);
    border-color: var(--border-hover);
    color: var(--fg);
  }

  .tag-link.active {
    background: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
</style>
