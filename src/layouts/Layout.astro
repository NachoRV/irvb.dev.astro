---
import "../styles/global.css";
import Header from "../components/Header/Header.tsx";
import Footer from "../components/Footer.astro";
import Cookies from "../components/Cookies.astro";
interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  {
    label: "Home",
    href: "/",
  },
  {
    label: "About",
    href: "/about",
  },
  {
    label: "Articles",
    href: "/blog",
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Blog personal sobre desarrollo web y tecnología"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header navItems={navItems} client:load />
    <slot />
    <Cookies />
    <Footer />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JJ1N9ZMLLR"
    ></script>
    <script>
      import "../scripts/google.js";
    </script>
  </body>
</html>
