---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = allPosts.slice(0, 6);
---

<Layout title="irvb.dev - Desarrollo Web">
  <main>
    <div class="page-container">
      <section class="hero">
        <p class="hero-label">Blog personal</p>
        <h1>irvb.dev</h1>
        <p class="hero-description">
          Documentando mi camino aprendiendo <strong>programación</strong> y <strong>emprendimiento</strong>
          mientras construyo aplicaciones para aprender sobre negocios online. Comparto lo que funciona,
          lo que no y las lecciones que voy descubriendo.
        </p>
      </section>

      <section class="recent-posts">
        <div class="section-header">
          <h2>Artículos recientes</h2>
          <a href="/blog" class="view-all-link">Ver todos &rarr;</a>
        </div>
        <div class="posts-grid">
          {
            recentPosts.map((post) => (
              <PostCard
                img={post.data.image.url}
                title={post.data.title}
                href={`/posts/${post.slug}/`}
                body={post.data.description}
              />
            ))
          }
        </div>
      </section>
    </div>
  </main>

  <style>
    .page-container {
      width: 100%;
      max-width: 64rem;
    }

    .hero {
      padding: 3rem 0 4rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 3rem;
    }

    .hero-label {
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--fg-subtle);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin: 0 0 0.75rem;
    }

    h1 {
      font-size: clamp(2.5rem, 6vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.035em;
      margin-bottom: 1.25rem;
      color: var(--fg);
      line-height: 1.1;
    }

    .hero-description {
      font-size: 1.125rem;
      color: var(--fg-muted);
      line-height: 1.7;
      max-width: 40rem;
      margin: 0;
    }

    .hero-description strong {
      color: var(--fg);
      font-weight: 600;
    }

    .recent-posts {
      padding-bottom: 3rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-size: 0.8125rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--fg-subtle);
      margin: 0;
    }

    .view-all-link {
      font-size: 0.8125rem;
      font-family: var(--font-mono);
      color: var(--fg-subtle);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .view-all-link:hover {
      color: var(--fg);
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .posts-grid {
        grid-template-columns: 1fr;
      }

      .hero {
        padding: 2rem 0 3rem;
      }

      h1 {
        font-size: 2rem;
      }

      .hero-description {
        font-size: 1rem;
      }
    }
  </style>
</Layout>
