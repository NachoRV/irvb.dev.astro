---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import HighlightText from "../components/HighlightText.astro";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const recentPosts = allPosts.slice(0, 3);
---

<Layout title="irvb.dev - Desarrollo Web">
  <main>
    <section class="hero">
      <h1>
        Bienvenido a
        <HighlightText text="irvb.dev" />
      </h1>
      <p>
        Este blog documenta mi camino aprendiendo <span
          class="highlight">programación</span> y <span class="highlight">emprendimiento</span>
          mientras construyo aplicaciones para aprender sobre negocios online. Aquí
          comparto lo que funciona, lo que no y las lecciones que voy
          descubriendo por el camino.
        </p>
          <section class="recent-posts">
            <h2>Artículos Recientes</h2>
            <div class="posts-grid">
              {
                recentPosts.map((post) => (
                  <PostCard
                    img={post.data.image.url}
                    title={post.data.title}
                    href={`/posts/${post.slug}/`}
                    body={post.data.description}
                  />
                ))
              }
            </div>
            <div class="view-all">
              <a href="/blog" class="btn-primary">Ver todos los artículos</a>
            </div>
          </section>
        </span>
      </p>

      <style>
        main {
          margin: auto;
          padding: 2rem 1rem;
          width: 100%;
          max-width: 1000px;
        }

        .hero {
          text-align: center;
          margin-bottom: 4rem;
          padding: 2rem 0;
        }

        h1 {
          font-size: 3.5rem;
          font-weight: 700;
          line-height: 1.2;
          margin-bottom: 1rem;
          color: var(--color-black);
        }

        .hero p {
          font-size: 1.3rem;
          color: var(--color-gray);
          line-height: 1.6;
        }

        .highlight {
          color: var(--color-pink);
          font-weight: 600;
        }

        .recent-posts {
          margin-top: 3rem;
        }

        .recent-posts h2 {
          font-size: 2rem;
          margin-bottom: 2rem;
          color: var(--color-black);
        }

        .posts-grid {
          display: grid;
          gap: 2rem;
          margin-bottom: 2rem;
        }

        .view-all {
          text-align: center;
          margin-top: 2rem;
        }

        .btn-primary {
          display: inline-block;
          padding: 0.75rem 2rem;
          background: linear-gradient(
            135deg,
            var(--color-pink),
            var(--color-yellow)
          );
          color: var(--color-black);
          text-decoration: none;
          border-radius: 0.5rem;
          font-weight: 600;
          transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
        }

        .btn-primary:hover {
          transform: translateY(-2px);
          box-shadow: 0 8px 16px rgba(208, 105, 191, 0.3);
        }

        @media (max-width: 768px) {
          h1 {
            font-size: 2rem;
          }

          .hero p {
            font-size: 1rem;
          }

          .recent-posts h2 {
            font-size: 1.5rem;
          }
        }
        :root.dark h1 {
          color: var(--color-white);
        }
        :root.dark .recent-posts h2 {
          color: var(--color-white);
        }
      </style>
    </section>
  </main></Layout
>
