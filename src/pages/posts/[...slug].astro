---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("posts");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Calcular tiempo de lectura (aprox 200 palabras por minuto)
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---

<Layout title={entry.data.title}>
  <article class="post-article">
    <header class="post-header">
      <div class="post-header-content">
        <div class="post-meta">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString('es-ES', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          <span class="meta-separator">&middot;</span>
          <span>{readingTime} min de lectura</span>
          <span class="meta-separator">&middot;</span>
          <span>{entry.data.author}</span>
        </div>

        <h1 class="post-title">{entry.data.title}</h1>

        {entry.data.tags && (
          <div class="tags-list">
            {entry.data.tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag-badge">{tag}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="post-image-wrapper">
      <img src={entry.data.image.url} alt={entry.data.image.alt} class="post-hero-image" />
    </div>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <hr />
      <p class="post-footer-text">
        ¿Te gustó este artículo? Comparte tus pensamientos en
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a> o
        <a href="mailto:contact@irvb.dev">contáctame por email</a>.
      </p>
      <a href="/blog" class="back-link">&larr; Volver a artículos</a>
    </footer>
  </article>
</Layout>

<style>
  .post-article {
    width: 100%;
    max-width: 48rem;
    margin: 0 auto;
  }

  /* Header */
  .post-header {
    margin-bottom: 2rem;
  }

  .post-header-content {
    max-width: 100%;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--fg-subtle);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .meta-separator {
    color: var(--border-hover);
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 1.25rem 0;
    color: var(--fg);
    letter-spacing: -0.025em;
  }

  .tags-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-badge {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    transition: all 0.15s ease;
  }

  .tag-badge:hover {
    background: var(--bg-muted);
    border-color: var(--border-hover);
    color: var(--fg);
  }

  /* Post Image */
  .post-image-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    border: 1px solid var(--border);
  }

  .post-hero-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Post Content */
  .post-content {
    margin-bottom: 3rem;
  }

  :global(.post-content h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    color: var(--fg);
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    letter-spacing: -0.015em;
  }

  :global(.post-content h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--fg);
  }

  :global(.post-content p) {
    font-size: 1rem;
    line-height: 1.8;
    margin: 1rem 0;
    color: var(--fg-muted);
  }

  :global(.post-content ul),
  :global(.post-content ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  :global(.post-content li) {
    margin: 0.375rem 0;
    line-height: 1.8;
    color: var(--fg-muted);
  }

  :global(.post-content a) {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-hover);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }

  :global(.post-content a:hover) {
    text-decoration-color: var(--fg);
  }

  :global(.post-content img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  :global(.post-content code) {
    background: var(--bg-muted);
    color: var(--fg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  :global(.post-content pre) {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  :global(.post-content pre code) {
    background: none;
    color: inherit;
    padding: 0;
    border-radius: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  :global(.post-content blockquote) {
    border-left: 3px solid var(--border-hover);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--fg-subtle);
    font-style: italic;
  }

  /* Post Footer */
  .post-footer {
    padding-top: 2rem;
  }

  .post-footer hr {
    border: none;
    height: 1px;
    background: var(--border);
    margin-bottom: 1.5rem;
  }

  .post-footer-text {
    color: var(--fg-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .post-footer-text a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-hover);
    text-underline-offset: 2px;
    font-weight: 500;
    transition: text-decoration-color 0.15s ease;
  }

  .post-footer-text a:hover {
    text-decoration-color: var(--fg);
  }

  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--fg-subtle);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--fg);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .post-title {
      font-size: 1.5rem;
    }

    .post-meta {
      font-size: 0.75rem;
    }

    :global(.post-content h2) {
      font-size: 1.25rem;
      margin: 2rem 0 0.75rem;
    }

    :global(.post-content h3) {
      font-size: 1.1rem;
    }
  }
</style>
