---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import TagsNav from "../../components/TagsNav.astro";
import HighlightText from "../../components/HighlightText.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("posts", ({ data }) => !data.draft);
  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag)
    );
    return {
      params: { tag },
      props: { posts: filteredPosts, allTags: uniqueTags },
    };
  });
}

const { tag } = Astro.params;
const { posts, allTags } = Astro.props;
---

<BaseLayout title={`${tag} - irvb.dev`}>
  <main>
    <h1 class="text-xl">
      Artículos con etiqueta: <HighlightText text={tag} color="blue" />
    </h1>
    <TagsNav tags={allTags} activeTag={tag} />
    <section class="posts-section">
      {
        posts.length > 0 ? (
          posts.map((post) => (
            <PostCard
              img={post.data.image.url}
              title={post.data.title}
              href={`/posts/${post.slug}/`}
              body={post.data.description}
            />
          ))
        ) : (
          <p class="no-posts">No hay artículos con esta etiqueta.</p>
        )
      }
    </section>
    <style>
      .posts-section {
        margin-top: 2rem;
      }
      .no-posts {
        text-align: center;
        padding: 2rem;
        color: var(--color-gray);
        font-style: italic;
      }
    </style>
  </main>
</BaseLayout>
